# Copy to .env.local and fill in.

# Clerk — sign up at clerk.com, create an application, copy keys from "API keys"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Where to reach the broker. /api/* requests are proxied here by next.config.ts.
# Local dev: http://127.0.0.1:8787
# Production (Vercel): https://gstack-broker.fly.dev
GSTACK_BROKER_URL=http://127.0.0.1:8787
